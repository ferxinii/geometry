        p4x, p4y, p4z);
}

// ---------------------------------------------------------------------------
// MPFR helpers shared by all inSphere MPFR fallbacks.
// 640 bits: degree-10 poly in 53-bit inputs needs at most 10*53+ceil(log2(terms))
// ≈ 540 bits; 640 gives a comfortable margin.
// ---------------------------------------------------------------------------
static void impl_mpfr_det3(mpfr_t result,
    mpfr_t m00, mpfr_t m01, mpfr_t m02,
    mpfr_t m10, mpfr_t m11, mpfr_t m12,
    mpfr_t m20, mpfr_t m21, mpfr_t m22,
    mpfr_prec_t prec)
{
    mpfr_t t0, t1, tmp;
    mpfr_init2(t0, prec); mpfr_init2(t1, prec); mpfr_init2(tmp, prec);
    mpfr_mul(t0, m11, m22, MPFR_RNDN); mpfr_mul(t1, m12, m21, MPFR_RNDN);
    mpfr_sub(tmp, t0, t1, MPFR_RNDN); mpfr_mul(result, m00, tmp, MPFR_RNDN);
    mpfr_mul(t0, m10, m22, MPFR_RNDN); mpfr_mul(t1, m12, m20, MPFR_RNDN);
    mpfr_sub(tmp, t0, t1, MPFR_RNDN); mpfr_mul(tmp, m01, tmp, MPFR_RNDN);
    mpfr_sub(result, result, tmp, MPFR_RNDN);
    mpfr_mul(t0, m10, m21, MPFR_RNDN); mpfr_mul(t1, m11, m20, MPFR_RNDN);
    mpfr_sub(tmp, t0, t1, MPFR_RNDN); mpfr_mul(tmp, m02, tmp, MPFR_RNDN);
    mpfr_add(result, result, tmp, MPFR_RNDN);
    mpfr_clear(t0); mpfr_clear(t1); mpfr_clear(tmp);
}

static void impl_mpfr_det4(mpfr_t result, mpfr_t m[4][4], mpfr_prec_t prec)
{
    mpfr_t t0, t1;
    mpfr_init2(t0, prec); mpfr_init2(t1, prec);
    impl_mpfr_det3(t0, m[1][1],m[1][2],m[1][3], m[2][1],m[2][2],m[2][3], m[3][1],m[3][2],m[3][3], prec);
    mpfr_mul(result, m[0][0], t0, MPFR_RNDN);
    impl_mpfr_det3(t0, m[1][0],m[1][2],m[1][3], m[2][0],m[2][2],m[2][3], m[3][0],m[3][2],m[3][3], prec);
    mpfr_mul(t1, m[0][1], t0, MPFR_RNDN); mpfr_sub(result, result, t1, MPFR_RNDN);
    impl_mpfr_det3(t0, m[1][0],m[1][1],m[1][3], m[2][0],m[2][1],m[2][3], m[3][0],m[3][1],m[3][3], prec);
    mpfr_mul(t1, m[0][2], t0, MPFR_RNDN); mpfr_add(result, result, t1, MPFR_RNDN);
    impl_mpfr_det3(t0, m[1][0],m[1][1],m[1][2], m[2][0],m[2][1],m[2][2], m[3][0],m[3][1],m[3][2], prec);
    mpfr_mul(t1, m[0][3], t0, MPFR_RNDN); mpfr_sub(result, result, t1, MPFR_RNDN);
    mpfr_clear(t0); mpfr_clear(t1);
}

// Fills col 3 of m[4][4] with squared norms of the first 3 columns, then
// computes the 4x4 determinant into result.
static int impl_mpfr_insphere_det4(mpfr_t m[4][4], mpfr_prec_t prec)
{
    mpfr_t t0, t1, result;
    mpfr_init2(t0, prec); mpfr_init2(t1, prec); mpfr_init2(result, prec);
    for (int i = 0; i < 4; i++) {
        mpfr_mul(t0, m[i][0], m[i][0], MPFR_RNDN);
        mpfr_mul(t1, m[i][1], m[i][1], MPFR_RNDN); mpfr_add(t0, t0, t1, MPFR_RNDN);
        mpfr_mul(t1, m[i][2], m[i][2], MPFR_RNDN); mpfr_add(m[i][3], t0, t1, MPFR_RNDN);
    }
    impl_mpfr_det4(result, m, prec);
    int s = mpfr_sgn(result);
    mpfr_clear(t0); mpfr_clear(t1); mpfr_clear(result);
    return s;
}

// ---------------------------------------------------------------------------
// inSphere_IEEEE MPFR exact fallback
// ---------------------------------------------------------------------------
struct inSphere_IEEEE_mpfr {
    static constexpr bool stateful = false;
    static constexpr bool updates  = false;

    template <typename Real>
    static int apply(
        Real i1_v1x, Real i1_v1y, Real i1_v1z,
        Real i1_v2x, Real i1_v2y, Real i1_v2z, Real i1_t,
        Real p2x, Real p2y, Real p2z,
        Real p3x, Real p3y, Real p3z,
        Real p4x, Real p4y, Real p4z,
        Real p5x, Real p5y, Real p5z)
    {
        static constexpr mpfr_prec_t prec = 640;
        mpfr_t m[4][4], t0;
        for (int i = 0; i < 4; i++)
            for (int j = 0; j < 4; j++)
                mpfr_init2(m[i][j], prec);
        mpfr_init2(t0, prec);

        // Row 0: i1x - p5x = i1_t*(i1_v1x - i1_v2x) + i1_v2x - p5x
        auto set_implicit_row = [&](int row,
            double v1x, double v1y, double v1z,
            double v2x, double v2y, double v2z, double t,
            double refx, double refy, double refz) {
            mpfr_set_d(t0, v1x, MPFR_RNDN); mpfr_sub_d(t0, t0, v2x, MPFR_RNDN);
            mpfr_mul_d(t0, t0, t, MPFR_RNDN); mpfr_add_d(m[row][0], t0, v2x, MPFR_RNDN);
            mpfr_sub_d(m[row][0], m[row][0], refx, MPFR_RNDN);
            mpfr_set_d(t0, v1y, MPFR_RNDN); mpfr_sub_d(t0, t0, v2y, MPFR_RNDN);
            mpfr_mul_d(t0, t0, t, MPFR_RNDN); mpfr_add_d(m[row][1], t0, v2y, MPFR_RNDN);
            mpfr_sub_d(m[row][1], m[row][1], refy, MPFR_RNDN);
            mpfr_set_d(t0, v1z, MPFR_RNDN); mpfr_sub_d(t0, t0, v2z, MPFR_RNDN);
            mpfr_mul_d(t0, t0, t, MPFR_RNDN); mpfr_add_d(m[row][2], t0, v2z, MPFR_RNDN);
            mpfr_sub_d(m[row][2], m[row][2], refz, MPFR_RNDN);
        };
        auto set_explicit_row = [&](int row,
            double px, double py, double pz,
            double refx, double refy, double refz) {
            mpfr_set_d(m[row][0], px, MPFR_RNDN); mpfr_sub_d(m[row][0], m[row][0], refx, MPFR_RNDN);
            mpfr_set_d(m[row][1], py, MPFR_RNDN); mpfr_sub_d(m[row][1], m[row][1], refy, MPFR_RNDN);
            mpfr_set_d(m[row][2], pz, MPFR_RNDN); mpfr_sub_d(m[row][2], m[row][2], refz, MPFR_RNDN);
        };

        set_implicit_row(0, (double)i1_v1x,(double)i1_v1y,(double)i1_v1z,
                            (double)i1_v2x,(double)i1_v2y,(double)i1_v2z,(double)i1_t,
                            (double)p5x,(double)p5y,(double)p5z);
        set_explicit_row(1, (double)p2x,(double)p2y,(double)p2z, (double)p5x,(double)p5y,(double)p5z);
        set_explicit_row(2, (double)p3x,(double)p3y,(double)p3z, (double)p5x,(double)p5y,(double)p5z);
        set_explicit_row(3, (double)p4x,(double)p4y,(double)p4z, (double)p5x,(double)p5y,(double)p5z);

        int s = impl_mpfr_insphere_det4(m, prec);

        mpfr_clear(t0);
        for (int i = 0; i < 4; i++)
            for (int j = 0; j < 4; j++)
                mpfr_clear(m[i][j]);
        return s;
    }
};

// ---------------------------------------------------------------------------
// inSphere_IEEEE
// Arguments (19): i1(7) p2(3) p3(3) p4(3) p5(3)
//
// | i1x-p5x  i1y-p5y  i1z-p5z  |i1-p5|^2 |
// | p2x-p5x  p2y-p5y  p2z-p5z  |p2-p5|^2 |
// | p3x-p5x  p3y-p5y  p3z-p5z  |p3-p5|^2 |
// | p4x-p5x  p4y-p5y  p4z-p5z  |p4-p5|^2 |
// ---------------------------------------------------------------------------
namespace inSphere_IEEEE_impl {
    constexpr auto i1_v1x = grp::_1;
    constexpr auto i1_v1y = grp::_2;
    constexpr auto i1_v1z = grp::_3;
    constexpr auto i1_v2x = grp::_4;
    constexpr auto i1_v2y = grp::_5;
    constexpr auto i1_v2z = grp::_6;
    constexpr auto i1_t   = grp::_7;
    constexpr auto p2x    = grp::_8;
    constexpr auto p2y    = grp::_9;
    constexpr auto p2z    = grp::_10;
    constexpr auto p3x    = grp::_11;
    constexpr auto p3y    = grp::_12;
    constexpr auto p3z    = grp::_13;
    constexpr auto p4x    = grp::_14;
    constexpr auto p4y    = grp::_15;
    constexpr auto p4z    = grp::_16;
    constexpr auto p5x    = grp::_17;
    constexpr auto p5y    = grp::_18;
    constexpr auto p5z    = grp::_19;

    // Row 1 (implicit i1): i1x - p5x = t*(v1x - v2x) + (v2x - p5x)
    constexpr auto dax = i1_t * (i1_v1x - i1_v2x) + (i1_v2x - p5x);
    constexpr auto day = i1_t * (i1_v1y - i1_v2y) + (i1_v2y - p5y);
    constexpr auto daz = i1_t * (i1_v1z - i1_v2z) + (i1_v2z - p5z);
    // Rows 2-4 (explicit)
    constexpr auto dbx = p2x - p5x;
    constexpr auto dby = p2y - p5y;
    constexpr auto dbz = p2z - p5z;
    constexpr auto dcx = p3x - p5x;
    constexpr auto dcy = p3y - p5y;
    constexpr auto dcz = p3z - p5z;
    constexpr auto ddx = p4x - p5x;
    constexpr auto ddy = p4y - p5y;
    constexpr auto ddz = p4z - p5z;

    constexpr auto la = dax*dax + day*day + daz*daz;
    constexpr auto lb = dbx*dbx + dby*dby + dbz*dbz;
    constexpr auto lc = dcx*dcx + dcy*dcy + dcz*dcz;
    constexpr auto ld = ddx*ddx + ddy*ddy + ddz*ddz;

    using expr_t = grp::det<
        decltype(dax), decltype(day), decltype(daz), decltype(la),
        decltype(dbx), decltype(dby), decltype(dbz), decltype(lb),
        decltype(dcx), decltype(dcy), decltype(dcz), decltype(lc),
        decltype(ddx), decltype(ddy), decltype(ddz), decltype(ld)
    >;
    constexpr auto expr = expr_t{};

    using semi_static = grp::forward_error_semi_static<expr, double, grp::robust_rules<true>>;
    using pred        = grp::staged_predicate<semi_static, inSphere_IEEEE_mpfr>;
}

extern "C" int inSphere_IEEEE(
    double i1_v1x, double i1_v1y, double i1_v1z,
    double i1_v2x, double i1_v2y, double i1_v2z, double i1_t,
    double p2x,    double p2y,    double p2z,
    double p3x,    double p3y,    double p3z,
    double p4x,    double p4y,    double p4z,
    double p5x,    double p5y,    double p5z)
{
    int orient_sign = orient3d_IEEE_impl::pred{}.apply(
        i1_v1x, i1_v1y, i1_v1z,
        i1_v2x, i1_v2y, i1_v2z, i1_t,
        p2x, p2y, p2z,
        p3x, p3y, p3z,
        p4x, p4y, p4z);
    if (orient_sign == 0) return 0;

    int D_sign = inSphere_IEEEE_impl::pred{}.apply(
        i1_v1x, i1_v1y, i1_v1z,
        i1_v2x, i1_v2y, i1_v2z, i1_t,
        p2x, p2y, p2z,
        p3x, p3y, p3z,
        p4x, p4y, p4z,
        p5x, p5y, p5z);
    int out = -orient_sign * D_sign;
    if (out > 0) return 1;
    else if (out < 0) return -1;
    else return 0;
}

// ---------------------------------------------------------------------------
// inSphere_IIEEE MPFR exact fallback
// ---------------------------------------------------------------------------
struct inSphere_IIEEE_mpfr {
    static constexpr bool stateful = false;
    static constexpr bool updates  = false;

    template <typename Real>
    static int apply(
        Real i1_v1x, Real i1_v1y, Real i1_v1z,
        Real i1_v2x, Real i1_v2y, Real i1_v2z, Real i1_t,
        Real i2_v1x, Real i2_v1y, Real i2_v1z,
        Real i2_v2x, Real i2_v2y, Real i2_v2z, Real i2_t,
        Real p3x, Real p3y, Real p3z,
        Real p4x, Real p4y, Real p4z,
        Real p5x, Real p5y, Real p5z)
    {
        static constexpr mpfr_prec_t prec = 640;
        mpfr_t m[4][4], t0;
        for (int i = 0; i < 4; i++)
            for (int j = 0; j < 4; j++)
                mpfr_init2(m[i][j], prec);
        mpfr_init2(t0, prec);

        auto set_implicit_row = [&](int row,
            double v1x, double v1y, double v1z,
            double v2x, double v2y, double v2z, double t,
            double refx, double refy, double refz) {
            mpfr_set_d(t0, v1x, MPFR_RNDN); mpfr_sub_d(t0, t0, v2x, MPFR_RNDN);
            mpfr_mul_d(t0, t0, t, MPFR_RNDN); mpfr_add_d(m[row][0], t0, v2x, MPFR_RNDN);
            mpfr_sub_d(m[row][0], m[row][0], refx, MPFR_RNDN);
            mpfr_set_d(t0, v1y, MPFR_RNDN); mpfr_sub_d(t0, t0, v2y, MPFR_RNDN);
            mpfr_mul_d(t0, t0, t, MPFR_RNDN); mpfr_add_d(m[row][1], t0, v2y, MPFR_RNDN);
            mpfr_sub_d(m[row][1], m[row][1], refy, MPFR_RNDN);
            mpfr_set_d(t0, v1z, MPFR_RNDN); mpfr_sub_d(t0, t0, v2z, MPFR_RNDN);
            mpfr_mul_d(t0, t0, t, MPFR_RNDN); mpfr_add_d(m[row][2], t0, v2z, MPFR_RNDN);
            mpfr_sub_d(m[row][2], m[row][2], refz, MPFR_RNDN);
        };
        auto set_explicit_row = [&](int row,
            double px, double py, double pz,
            double refx, double refy, double refz) {
            mpfr_set_d(m[row][0], px, MPFR_RNDN); mpfr_sub_d(m[row][0], m[row][0], refx, MPFR_RNDN);
            mpfr_set_d(m[row][1], py, MPFR_RNDN); mpfr_sub_d(m[row][1], m[row][1], refy, MPFR_RNDN);
            mpfr_set_d(m[row][2], pz, MPFR_RNDN); mpfr_sub_d(m[row][2], m[row][2], refz, MPFR_RNDN);
        };

        set_implicit_row(0, (double)i1_v1x,(double)i1_v1y,(double)i1_v1z,
                            (double)i1_v2x,(double)i1_v2y,(double)i1_v2z,(double)i1_t,
                            (double)p5x,(double)p5y,(double)p5z);
        set_implicit_row(1, (double)i2_v1x,(double)i2_v1y,(double)i2_v1z,
                            (double)i2_v2x,(double)i2_v2y,(double)i2_v2z,(double)i2_t,
                            (double)p5x,(double)p5y,(double)p5z);
        set_explicit_row(2, (double)p3x,(double)p3y,(double)p3z, (double)p5x,(double)p5y,(double)p5z);
        set_explicit_row(3, (double)p4x,(double)p4y,(double)p4z, (double)p5x,(double)p5y,(double)p5z);

        int s = impl_mpfr_insphere_det4(m, prec);
        mpfr_clear(t0);
        for (int i = 0; i < 4; i++)
            for (int j = 0; j < 4; j++)
                mpfr_clear(m[i][j]);
        return s;
    }
};

