    constexpr auto dbx = i2_t * (i2_v1x - i2_v2x) + (i2_v2x - p5x);
    constexpr auto dby = i2_t * (i2_v1y - i2_v2y) + (i2_v2y - p5y);
    constexpr auto dbz = i2_t * (i2_v1z - i2_v2z) + (i2_v2z - p5z);
    constexpr auto dcx = i3_t * (i3_v1x - i3_v2x) + (i3_v2x - p5x);
    constexpr auto dcy = i3_t * (i3_v1y - i3_v2y) + (i3_v2y - p5y);
    constexpr auto dcz = i3_t * (i3_v1z - i3_v2z) + (i3_v2z - p5z);
    constexpr auto ddx = p4x - p5x;
    constexpr auto ddy = p4y - p5y;
    constexpr auto ddz = p4z - p5z;

    constexpr auto la = dax*dax + day*day + daz*daz;
    constexpr auto lb = dbx*dbx + dby*dby + dbz*dbz;
    constexpr auto lc = dcx*dcx + dcy*dcy + dcz*dcz;
    constexpr auto ld = ddx*ddx + ddy*ddy + ddz*ddz;

    using expr_t = grp::det<
        decltype(dax), decltype(day), decltype(daz), decltype(la),
        decltype(dbx), decltype(dby), decltype(dbz), decltype(lb),
        decltype(dcx), decltype(dcy), decltype(dcz), decltype(lc),
        decltype(ddx), decltype(ddy), decltype(ddz), decltype(ld)
    >;
    constexpr auto expr = expr_t{};

    using semi_static = grp::forward_error_semi_static<expr, double, grp::robust_rules<true>>;
    using pred        = grp::staged_predicate<semi_static, inSphere_IIIEE_mpfr>;
}

extern "C" int inSphere_IIIEE(
    double i1_v1x, double i1_v1y, double i1_v1z,
    double i1_v2x, double i1_v2y, double i1_v2z, double i1_t,
    double i2_v1x, double i2_v1y, double i2_v1z,
    double i2_v2x, double i2_v2y, double i2_v2z, double i2_t,
    double i3_v1x, double i3_v1y, double i3_v1z,
    double i3_v2x, double i3_v2y, double i3_v2z, double i3_t,
    double p4x,    double p4y,    double p4z,
    double p5x,    double p5y,    double p5z)
{
    int orient_sign = orient3d_IIIE_impl::pred{}.apply(
        i1_v1x, i1_v1y, i1_v1z,
        i1_v2x, i1_v2y, i1_v2z, i1_t,
        i2_v1x, i2_v1y, i2_v1z,
        i2_v2x, i2_v2y, i2_v2z, i2_t,
        i3_v1x, i3_v1y, i3_v1z,
        i3_v2x, i3_v2y, i3_v2z, i3_t,
        p4x, p4y, p4z);
    if (orient_sign == 0) return 0;

    int D_sign = inSphere_IIIEE_impl::pred{}.apply(
        i1_v1x, i1_v1y, i1_v1z,
        i1_v2x, i1_v2y, i1_v2z, i1_t,
        i2_v1x, i2_v1y, i2_v1z,
        i2_v2x, i2_v2y, i2_v2z, i2_t,
        i3_v1x, i3_v1y, i3_v1z,
        i3_v2x, i3_v2y, i3_v2z, i3_t,
        p4x, p4y, p4z,
        p5x, p5y, p5z);
    int out = -orient_sign * D_sign;
    if (out > 0) return 1;
    else if (out < 0) return -1;
    else return 0;
}

// ---------------------------------------------------------------------------
// inSphere_IIIIE MPFR exact fallback
// ---------------------------------------------------------------------------
struct inSphere_IIIIE_mpfr {
    static constexpr bool stateful = false;
    static constexpr bool updates  = false;

    template <typename Real>
    static int apply(
        Real i1_v1x, Real i1_v1y, Real i1_v1z,
        Real i1_v2x, Real i1_v2y, Real i1_v2z, Real i1_t,
        Real i2_v1x, Real i2_v1y, Real i2_v1z,
        Real i2_v2x, Real i2_v2y, Real i2_v2z, Real i2_t,
        Real i3_v1x, Real i3_v1y, Real i3_v1z,
        Real i3_v2x, Real i3_v2y, Real i3_v2z, Real i3_t,
        Real i4_v1x, Real i4_v1y, Real i4_v1z,
        Real i4_v2x, Real i4_v2y, Real i4_v2z, Real i4_t,
        Real p5x, Real p5y, Real p5z)
    {
        static constexpr mpfr_prec_t prec = 640;
        mpfr_t m[4][4], t0;
        for (int i = 0; i < 4; i++)
            for (int j = 0; j < 4; j++)
                mpfr_init2(m[i][j], prec);
        mpfr_init2(t0, prec);

        auto set_implicit_row = [&](int row,
            double v1x, double v1y, double v1z,
            double v2x, double v2y, double v2z, double t,
            double refx, double refy, double refz) {
            mpfr_set_d(t0, v1x, MPFR_RNDN); mpfr_sub_d(t0, t0, v2x, MPFR_RNDN);
            mpfr_mul_d(t0, t0, t, MPFR_RNDN); mpfr_add_d(m[row][0], t0, v2x, MPFR_RNDN);
            mpfr_sub_d(m[row][0], m[row][0], refx, MPFR_RNDN);
            mpfr_set_d(t0, v1y, MPFR_RNDN); mpfr_sub_d(t0, t0, v2y, MPFR_RNDN);
            mpfr_mul_d(t0, t0, t, MPFR_RNDN); mpfr_add_d(m[row][1], t0, v2y, MPFR_RNDN);
            mpfr_sub_d(m[row][1], m[row][1], refy, MPFR_RNDN);
            mpfr_set_d(t0, v1z, MPFR_RNDN); mpfr_sub_d(t0, t0, v2z, MPFR_RNDN);
            mpfr_mul_d(t0, t0, t, MPFR_RNDN); mpfr_add_d(m[row][2], t0, v2z, MPFR_RNDN);
            mpfr_sub_d(m[row][2], m[row][2], refz, MPFR_RNDN);
        };

        set_implicit_row(0, (double)i1_v1x,(double)i1_v1y,(double)i1_v1z,
                            (double)i1_v2x,(double)i1_v2y,(double)i1_v2z,(double)i1_t,
                            (double)p5x,(double)p5y,(double)p5z);
        set_implicit_row(1, (double)i2_v1x,(double)i2_v1y,(double)i2_v1z,
                            (double)i2_v2x,(double)i2_v2y,(double)i2_v2z,(double)i2_t,
                            (double)p5x,(double)p5y,(double)p5z);
        set_implicit_row(2, (double)i3_v1x,(double)i3_v1y,(double)i3_v1z,
                            (double)i3_v2x,(double)i3_v2y,(double)i3_v2z,(double)i3_t,
                            (double)p5x,(double)p5y,(double)p5z);
        set_implicit_row(3, (double)i4_v1x,(double)i4_v1y,(double)i4_v1z,
                            (double)i4_v2x,(double)i4_v2y,(double)i4_v2z,(double)i4_t,
                            (double)p5x,(double)p5y,(double)p5z);

        int s = impl_mpfr_insphere_det4(m, prec);
        mpfr_clear(t0);
        for (int i = 0; i < 4; i++)
            for (int j = 0; j < 4; j++)
                mpfr_clear(m[i][j]);
        return s;
    }
};

// ---------------------------------------------------------------------------
// inSphere_IIIIE
// Arguments (31): i1(7) i2(7) i3(7) i4(7) p5(3)
// ---------------------------------------------------------------------------
namespace inSphere_IIIIE_impl {
    constexpr auto i1_v1x = grp::_1;
    constexpr auto i1_v1y = grp::_2;
    constexpr auto i1_v1z = grp::_3;
    constexpr auto i1_v2x = grp::_4;
    constexpr auto i1_v2y = grp::_5;
    constexpr auto i1_v2z = grp::_6;
    constexpr auto i1_t   = grp::_7;
    constexpr auto i2_v1x = grp::_8;
    constexpr auto i2_v1y = grp::_9;
    constexpr auto i2_v1z = grp::_10;
    constexpr auto i2_v2x = grp::_11;
    constexpr auto i2_v2y = grp::_12;
    constexpr auto i2_v2z = grp::_13;
    constexpr auto i2_t   = grp::_14;
    constexpr auto i3_v1x = grp::_15;
    constexpr auto i3_v1y = grp::_16;
    constexpr auto i3_v1z = grp::_17;
    constexpr auto i3_v2x = grp::_18;
    constexpr auto i3_v2y = grp::_19;
    constexpr auto i3_v2z = grp::_20;
    constexpr auto i3_t   = grp::_21;
    constexpr auto i4_v1x = grp::_22;
    constexpr auto i4_v1y = grp::_23;
    constexpr auto i4_v1z = grp::_24;
    constexpr auto i4_v2x = grp::_25;
    constexpr auto i4_v2y = grp::_26;
    constexpr auto i4_v2z = grp::_27;
    constexpr auto i4_t   = grp::_28;
    constexpr auto p5x    = grp::_29;
    constexpr auto p5y    = grp::_30;
    constexpr auto p5z    = grp::_31;

    constexpr auto dax = i1_t * (i1_v1x - i1_v2x) + (i1_v2x - p5x);
    constexpr auto day = i1_t * (i1_v1y - i1_v2y) + (i1_v2y - p5y);
    constexpr auto daz = i1_t * (i1_v1z - i1_v2z) + (i1_v2z - p5z);
    constexpr auto dbx = i2_t * (i2_v1x - i2_v2x) + (i2_v2x - p5x);
    constexpr auto dby = i2_t * (i2_v1y - i2_v2y) + (i2_v2y - p5y);
    constexpr auto dbz = i2_t * (i2_v1z - i2_v2z) + (i2_v2z - p5z);
    constexpr auto dcx = i3_t * (i3_v1x - i3_v2x) + (i3_v2x - p5x);
    constexpr auto dcy = i3_t * (i3_v1y - i3_v2y) + (i3_v2y - p5y);
    constexpr auto dcz = i3_t * (i3_v1z - i3_v2z) + (i3_v2z - p5z);
    constexpr auto ddx = i4_t * (i4_v1x - i4_v2x) + (i4_v2x - p5x);
    constexpr auto ddy = i4_t * (i4_v1y - i4_v2y) + (i4_v2y - p5y);
    constexpr auto ddz = i4_t * (i4_v1z - i4_v2z) + (i4_v2z - p5z);

    constexpr auto la = dax*dax + day*day + daz*daz;
    constexpr auto lb = dbx*dbx + dby*dby + dbz*dbz;
    constexpr auto lc = dcx*dcx + dcy*dcy + dcz*dcz;
    constexpr auto ld = ddx*ddx + ddy*ddy + ddz*ddz;

    using expr_t = grp::det<
        decltype(dax), decltype(day), decltype(daz), decltype(la),
        decltype(dbx), decltype(dby), decltype(dbz), decltype(lb),
        decltype(dcx), decltype(dcy), decltype(dcz), decltype(lc),
        decltype(ddx), decltype(ddy), decltype(ddz), decltype(ld)
    >;
    constexpr auto expr = expr_t{};

    using semi_static = grp::forward_error_semi_static<expr, double, grp::robust_rules<true>>;
    using pred        = grp::staged_predicate<semi_static, inSphere_IIIIE_mpfr>;
}

extern "C" int inSphere_IIIIE(
    double i1_v1x, double i1_v1y, double i1_v1z,
    double i1_v2x, double i1_v2y, double i1_v2z, double i1_t,
    double i2_v1x, double i2_v1y, double i2_v1z,
    double i2_v2x, double i2_v2y, double i2_v2z, double i2_t,
    double i3_v1x, double i3_v1y, double i3_v1z,
    double i3_v2x, double i3_v2y, double i3_v2z, double i3_t,
    double i4_v1x, double i4_v1y, double i4_v1z,
