template <std::size_t N>
struct [[deprecated("results_size — see template argument")]] show_stage_d_size {};
using _size_orient3d_IEEE = show_stage_d_size<orient3d_IEEE_impl::exact::results_size>*;
using _size_orient3d_IIEE = show_stage_d_size<orient3d_IIEE_impl::exact::results_size>*;
using _size_orient3d_IIIE = show_stage_d_size<orient3d_IIIE_impl::exact::results_size>*;
using _size_orient3d_IIII = show_stage_d_size<orient3d_IIII_impl::exact::results_size>*;
// inSphere predicates use MPFR fallback — no stage_d buffer to report.
#endif
