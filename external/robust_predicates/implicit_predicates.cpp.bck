#include "boost/geometry/extensions/generic_robust_predicates/strategies/cartesian/detail/expression_tree.hpp"
#include "boost/geometry/extensions/generic_robust_predicates/strategies/cartesian/detail/forward_error_bound.hpp"
#include "boost/geometry/extensions/generic_robust_predicates/strategies/cartesian/detail/stage_d.hpp"
#include "boost/geometry/extensions/generic_robust_predicates/strategies/cartesian/detail/stage_b.hpp"
#include "boost/geometry/extensions/generic_robust_predicates/strategies/cartesian/detail/staged_predicate.hpp"
#include "boost/geometry/extensions/generic_robust_predicates/strategies/cartesian/detail/expressions.hpp"

namespace grp = boost::geometry::detail::generic_robust_predicates;

// ---------------------------------------------------------------------------
// orient3d_IEEE
// Arguments (16): i1_v1x i1_v1y i1_v1z  i1_v2x i1_v2y i1_v2z  i1_t
//                 p2x p2y p2z   p3x p3y p3z   p4x p4y p4z
//
// Determinant:
// | i1x-p4x  i1y-p4y  i1z-p4z |     i1 = t*v1 + (1-t)*v2
// | p2x-p4x  p2y-p4y  p2z-p4z |
// | p3x-p4x  p3y-p4y  p3z-p4z |
//
// Row 1 substitution: i1x - p4x = t*(v1x - v2x) + (v2x - p4x)
// ---------------------------------------------------------------------------
namespace orient3d_IEEE_impl {
    constexpr auto i1_v1x = grp::_1;
    constexpr auto i1_v1y = grp::_2;
    constexpr auto i1_v1z = grp::_3;
    constexpr auto i1_v2x = grp::_4;
    constexpr auto i1_v2y = grp::_5;
    constexpr auto i1_v2z = grp::_6;
    constexpr auto i1_t   = grp::_7;
    constexpr auto p2x    = grp::_8;
    constexpr auto p2y    = grp::_9;
    constexpr auto p2z    = grp::_10;
    constexpr auto p3x    = grp::_11;
    constexpr auto p3y    = grp::_12;
    constexpr auto p3z    = grp::_13;
    constexpr auto p4x    = grp::_14;
    constexpr auto p4y    = grp::_15;
    constexpr auto p4z    = grp::_16;

    // Row 1 (implicit): i1x - p4x = t*(v1x - v2x) + (v2x - p4x)
    constexpr auto dax = i1_t * (i1_v1x - i1_v2x) + (i1_v2x - p4x);
    constexpr auto day = i1_t * (i1_v1y - i1_v2y) + (i1_v2y - p4y);
    constexpr auto daz = i1_t * (i1_v1z - i1_v2z) + (i1_v2z - p4z);
    // Row 2 (explicit p2)
    constexpr auto dbx = p2x - p4x;
    constexpr auto dby = p2y - p4y;
    constexpr auto dbz = p2z - p4z;
    // Row 3 (explicit p3)
    constexpr auto dcx = p3x - p4x;
    constexpr auto dcy = p3y - p4y;
    constexpr auto dcz = p3z - p4z;

    using expr_t = grp::det<
        decltype(dax), decltype(day), decltype(daz),
        decltype(dbx), decltype(dby), decltype(dbz),
        decltype(dcx), decltype(dcy), decltype(dcz)
    >;
    constexpr auto expr = expr_t{};

    using semi_static = grp::forward_error_semi_static<expr, double, grp::robust_rules<true>>;
    using exact       = grp::stage_d<expr, double>;
    using pred        = grp::staged_predicate<semi_static, exact>;
}

// ---------------------------------------------------------------------------
// orient3d_IIEE
// Arguments (20): i1(7) i2(7) p3(3) p4(3)
//
// | i1x-p4x  i1y-p4y  i1z-p4z |
// | i2x-p4x  i2y-p4y  i2z-p4z |
// | p3x-p4x  p3y-p4y  p3z-p4z |
// ---------------------------------------------------------------------------
namespace orient3d_IIEE_impl {
    constexpr auto i1_v1x = grp::_1;
    constexpr auto i1_v1y = grp::_2;
    constexpr auto i1_v1z = grp::_3;
    constexpr auto i1_v2x = grp::_4;
    constexpr auto i1_v2y = grp::_5;
    constexpr auto i1_v2z = grp::_6;
    constexpr auto i1_t   = grp::_7;
    constexpr auto i2_v1x = grp::_8;
    constexpr auto i2_v1y = grp::_9;
    constexpr auto i2_v1z = grp::_10;
    constexpr auto i2_v2x = grp::_11;
    constexpr auto i2_v2y = grp::_12;
    constexpr auto i2_v2z = grp::_13;
    constexpr auto i2_t   = grp::_14;
    constexpr auto p3x    = grp::_15;
    constexpr auto p3y    = grp::_16;
    constexpr auto p3z    = grp::_17;
    constexpr auto p4x    = grp::_18;
    constexpr auto p4y    = grp::_19;
    constexpr auto p4z    = grp::_20;

    // Row 1 (implicit i1)
    constexpr auto dax = i1_t * (i1_v1x - i1_v2x) + (i1_v2x - p4x);
    constexpr auto day = i1_t * (i1_v1y - i1_v2y) + (i1_v2y - p4y);
    constexpr auto daz = i1_t * (i1_v1z - i1_v2z) + (i1_v2z - p4z);
    // Row 2 (implicit i2)
    constexpr auto dbx = i2_t * (i2_v1x - i2_v2x) + (i2_v2x - p4x);
    constexpr auto dby = i2_t * (i2_v1y - i2_v2y) + (i2_v2y - p4y);
    constexpr auto dbz = i2_t * (i2_v1z - i2_v2z) + (i2_v2z - p4z);
    // Row 3 (explicit p3)
    constexpr auto dcx = p3x - p4x;
    constexpr auto dcy = p3y - p4y;
    constexpr auto dcz = p3z - p4z;

    using expr_t = grp::det<
        decltype(dax), decltype(day), decltype(daz),
        decltype(dbx), decltype(dby), decltype(dbz),
        decltype(dcx), decltype(dcy), decltype(dcz)
    >;
    constexpr auto expr = expr_t{};

    using semi_static = grp::forward_error_semi_static<expr, double, grp::robust_rules<true>>;
    using exact       = grp::stage_d<expr, double>;
    using pred        = grp::staged_predicate<semi_static, exact>;
}

// ---------------------------------------------------------------------------
// orient3d_IIIE
// Arguments (24): i1(7) i2(7) i3(7) p4(3)
//
// | i1x-p4x  i1y-p4y  i1z-p4z |
// | i2x-p4x  i2y-p4y  i2z-p4z |
// | i3x-p4x  i3y-p4y  i3z-p4z |
// ---------------------------------------------------------------------------
namespace orient3d_IIIE_impl {
    constexpr auto i1_v1x = grp::_1;
    constexpr auto i1_v1y = grp::_2;
    constexpr auto i1_v1z = grp::_3;
    constexpr auto i1_v2x = grp::_4;
    constexpr auto i1_v2y = grp::_5;
    constexpr auto i1_v2z = grp::_6;
    constexpr auto i1_t   = grp::_7;
    constexpr auto i2_v1x = grp::_8;
    constexpr auto i2_v1y = grp::_9;
    constexpr auto i2_v1z = grp::_10;
    constexpr auto i2_v2x = grp::_11;
    constexpr auto i2_v2y = grp::_12;
    constexpr auto i2_v2z = grp::_13;
    constexpr auto i2_t   = grp::_14;
    constexpr auto i3_v1x = grp::_15;
    constexpr auto i3_v1y = grp::_16;
    constexpr auto i3_v1z = grp::_17;
    constexpr auto i3_v2x = grp::_18;
    constexpr auto i3_v2y = grp::_19;
    constexpr auto i3_v2z = grp::_20;
    constexpr auto i3_t   = grp::_21;
    constexpr auto p4x    = grp::_22;
    constexpr auto p4y    = grp::_23;
    constexpr auto p4z    = grp::_24;

    // Row 1 (implicit i1)
    constexpr auto dax = i1_t * (i1_v1x - i1_v2x) + (i1_v2x - p4x);
    constexpr auto day = i1_t * (i1_v1y - i1_v2y) + (i1_v2y - p4y);
    constexpr auto daz = i1_t * (i1_v1z - i1_v2z) + (i1_v2z - p4z);
    // Row 2 (implicit i2)
    constexpr auto dbx = i2_t * (i2_v1x - i2_v2x) + (i2_v2x - p4x);
    constexpr auto dby = i2_t * (i2_v1y - i2_v2y) + (i2_v2y - p4y);
    constexpr auto dbz = i2_t * (i2_v1z - i2_v2z) + (i2_v2z - p4z);
    // Row 3 (implicit i3)
    constexpr auto dcx = i3_t * (i3_v1x - i3_v2x) + (i3_v2x - p4x);
    constexpr auto dcy = i3_t * (i3_v1y - i3_v2y) + (i3_v2y - p4y);
    constexpr auto dcz = i3_t * (i3_v1z - i3_v2z) + (i3_v2z - p4z);

    using expr_t = grp::det<
        decltype(dax), decltype(day), decltype(daz),
        decltype(dbx), decltype(dby), decltype(dbz),
        decltype(dcx), decltype(dcy), decltype(dcz)
    >;
    constexpr auto expr = expr_t{};

    using semi_static = grp::forward_error_semi_static<expr, double, grp::robust_rules<true>>;
    using exact       = grp::stage_d<expr, double>;
    using pred        = grp::staged_predicate<semi_static, exact>;
}

// ---------------------------------------------------------------------------
// orient3d_IIII
// Arguments (28): i1(7) i2(7) i3(7) i4(7)
//
// | i1x-i4x  i1y-i4y  i1z-i4z |
// | i2x-i4x  i2y-i4y  i2z-i4z |
// | i3x-i4x  i3y-i4y  i3z-i4z |
//
// ikx = ik_t*(ik_v1x - ik_v2x) + ik_v2x
// ikx - i4x = ik_t*(ik_v1x-ik_v2x) + ik_v2x - i4_t*(i4_v1x-i4_v2x) - i4_v2x
// ---------------------------------------------------------------------------
namespace orient3d_IIII_impl {
    constexpr auto i1_v1x = grp::_1;
    constexpr auto i1_v1y = grp::_2;
    constexpr auto i1_v1z = grp::_3;
    constexpr auto i1_v2x = grp::_4;
    constexpr auto i1_v2y = grp::_5;
    constexpr auto i1_v2z = grp::_6;
    constexpr auto i1_t   = grp::_7;
    constexpr auto i2_v1x = grp::_8;
    constexpr auto i2_v1y = grp::_9;
    constexpr auto i2_v1z = grp::_10;
    constexpr auto i2_v2x = grp::_11;
    constexpr auto i2_v2y = grp::_12;
    constexpr auto i2_v2z = grp::_13;
    constexpr auto i2_t   = grp::_14;
    constexpr auto i3_v1x = grp::_15;
    constexpr auto i3_v1y = grp::_16;
    constexpr auto i3_v1z = grp::_17;
    constexpr auto i3_v2x = grp::_18;
    constexpr auto i3_v2y = grp::_19;
    constexpr auto i3_v2z = grp::_20;
    constexpr auto i3_t   = grp::_21;
    constexpr auto i4_v1x = grp::_22;
    constexpr auto i4_v1y = grp::_23;
    constexpr auto i4_v1z = grp::_24;
    constexpr auto i4_v2x = grp::_25;
    constexpr auto i4_v2y = grp::_26;
    constexpr auto i4_v2z = grp::_27;
    constexpr auto i4_t   = grp::_28;

    // i4 evaluated: i4x = i4_t*(i4_v1x-i4_v2x) + i4_v2x
    constexpr auto i4x = i4_t * (i4_v1x - i4_v2x) + i4_v2x;
    constexpr auto i4y = i4_t * (i4_v1y - i4_v2y) + i4_v2y;
    constexpr auto i4z = i4_t * (i4_v1z - i4_v2z) + i4_v2z;

    // Row 1 (implicit i1): i1x - i4x
    constexpr auto dax = i1_t * (i1_v1x - i1_v2x) + (i1_v2x - i4x);
    constexpr auto day = i1_t * (i1_v1y - i1_v2y) + (i1_v2y - i4y);
    constexpr auto daz = i1_t * (i1_v1z - i1_v2z) + (i1_v2z - i4z);
    // Row 2 (implicit i2): i2x - i4x
    constexpr auto dbx = i2_t * (i2_v1x - i2_v2x) + (i2_v2x - i4x);
    constexpr auto dby = i2_t * (i2_v1y - i2_v2y) + (i2_v2y - i4y);
    constexpr auto dbz = i2_t * (i2_v1z - i2_v2z) + (i2_v2z - i4z);
    // Row 3 (implicit i3): i3x - i4x
    constexpr auto dcx = i3_t * (i3_v1x - i3_v2x) + (i3_v2x - i4x);
    constexpr auto dcy = i3_t * (i3_v1y - i3_v2y) + (i3_v2y - i4y);
    constexpr auto dcz = i3_t * (i3_v1z - i3_v2z) + (i3_v2z - i4z);

    using expr_t = grp::det<
        decltype(dax), decltype(day), decltype(daz),
        decltype(dbx), decltype(dby), decltype(dbz),
        decltype(dcx), decltype(dcy), decltype(dcz)
    >;
    constexpr auto expr = expr_t{};

    using semi_static = grp::forward_error_semi_static<expr, double, grp::robust_rules<true>>;
    using exact       = grp::stage_d<expr, double>;
    using pred        = grp::staged_predicate<semi_static, exact>;
}

extern "C" int orient3d_IIII(
    double i1_v1x, double i1_v1y, double i1_v1z,
    double i1_v2x, double i1_v2y, double i1_v2z, double i1_t,
    double i2_v1x, double i2_v1y, double i2_v1z,
    double i2_v2x, double i2_v2y, double i2_v2z, double i2_t,
    double i3_v1x, double i3_v1y, double i3_v1z,
    double i3_v2x, double i3_v2y, double i3_v2z, double i3_t,
    double i4_v1x, double i4_v1y, double i4_v1z,
    double i4_v2x, double i4_v2y, double i4_v2z, double i4_t)
{
    return orient3d_IIII_impl::pred{}.apply(
        i1_v1x, i1_v1y, i1_v1z,
        i1_v2x, i1_v2y, i1_v2z, i1_t,
        i2_v1x, i2_v1y, i2_v1z,
        i2_v2x, i2_v2y, i2_v2z, i2_t,
        i3_v1x, i3_v1y, i3_v1z,
        i3_v2x, i3_v2y, i3_v2z, i3_t,
        i4_v1x, i4_v1y, i4_v1z,
        i4_v2x, i4_v2y, i4_v2z, i4_t);
}

extern "C" int orient3d_IIIE(
    double i1_v1x, double i1_v1y, double i1_v1z,
    double i1_v2x, double i1_v2y, double i1_v2z, double i1_t,
    double i2_v1x, double i2_v1y, double i2_v1z,
    double i2_v2x, double i2_v2y, double i2_v2z, double i2_t,
    double i3_v1x, double i3_v1y, double i3_v1z,
    double i3_v2x, double i3_v2y, double i3_v2z, double i3_t,
    double p4x,    double p4y,    double p4z)
{
    return orient3d_IIIE_impl::pred{}.apply(
        i1_v1x, i1_v1y, i1_v1z,
        i1_v2x, i1_v2y, i1_v2z, i1_t,
        i2_v1x, i2_v1y, i2_v1z,
        i2_v2x, i2_v2y, i2_v2z, i2_t,
        i3_v1x, i3_v1y, i3_v1z,
        i3_v2x, i3_v2y, i3_v2z, i3_t,
        p4x, p4y, p4z);
}

extern "C" int orient3d_IIEE(
    double i1_v1x, double i1_v1y, double i1_v1z,
    double i1_v2x, double i1_v2y, double i1_v2z, double i1_t,
